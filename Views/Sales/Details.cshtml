@model StockMaster.Models.Sale
@{
    ViewData["Title"] = $"Sale Details - {Model.InvoiceNumber}";
    var currentUser = ViewBag.CurrentUser as StockMaster.Models.User;
}

<div class="row mb-4">
    <div class="col">
        <h2><i class="bi bi-receipt"></i> Sale Details</h2>
        <p class="text-muted">Invoice #: @Model.InvoiceNumber</p>
    </div>
    <div class="col-auto">
        <a asp-action="Receipt" asp-route-id="@Model.Id" class="btn btn-info">
            <i class="bi bi-printer"></i> Print Receipt
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <!-- Sale Items -->
        <div class="card mb-4">
            <div class="card-header">
                <h5>Items</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>SKU</th>
                                <th>Price</th>
                                <th>Quantity</th>
                                <th>Discount</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.SaleItems)
                            {
                                <tr>
                                    <td>@item.Product?.Name</td>
                                    <td>@item.Product?.SKU</td>
                                    <td>$@item.UnitPrice.ToString("N2")</td>
                                    <td>@item.Quantity</td>
                                    <td>$@item.Discount.ToString("N2")</td>
                                    <td>$@item.TotalPrice.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="5" class="text-end"><strong>Subtotal:</strong></td>
                                <td>$@Model.SubTotal.ToString("N2")</td>
                            </tr>
                            <tr>
                                <td colspan="5" class="text-end">Tax:</td>
                                <td>$@Model.TaxAmount.ToString("N2")</td>
                            </tr>
                            <tr>
                                <td colspan="5" class="text-end">Discount:</td>
                                <td>$@Model.DiscountAmount.ToString("N2")</td>
                            </tr>
                            <tr>
                                <td colspan="5" class="text-end"><strong>Total:</strong></td>
                                <td><strong>$@Model.TotalAmount.ToString("N2")</strong></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <!-- Sale Information -->
        <div class="card mb-4">
            <div class="card-header">
                <h5>Sale Information</h5>
            </div>
            <div class="card-body">
                <p><strong>Date:</strong> @Model.SaleDate.ToString("yyyy-MM-dd HH:mm")</p>
                <p><strong>Cashier:</strong> @(Model.User?.FullName ?? "N/A")</p>
                <p><strong>Payment Method:</strong> @Model.PaymentMethod</p>
                <p>
                    <strong>Payment Status:</strong>
                    <span class="badge bg-@(Model.PaymentStatus == PaymentStatus.Paid ? "success" :
                                                                       Model.PaymentStatus == PaymentStatus.PartiallyPaid ? "warning" :
                                                                       Model.PaymentStatus == PaymentStatus.Cancelled ? "danger" : "secondary")">
                        @Model.PaymentStatus
                    </span>
                </p>

                <hr />

                <p><strong>Amount Paid:</strong> $@Model.AmountPaid.ToString("N2")</p>
                <p><strong>Change:</strong> $@Model.ChangeAmount.ToString("N2")</p>
                @if (Model.DueAmount > 0)
                {
                    <p><strong>Due Amount:</strong> <span class="text-danger">$@Model.DueAmount.ToString("N2")</span></p>
                }

                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <hr />
                    <p><strong>Notes:</strong></p>
                    <p class="text-muted">@Model.Notes</p>
                }
            </div>
        </div>

        <!-- Actions -->
        @if (Model.PaymentStatus != PaymentStatus.Cancelled &&
                (currentUser?.Role == UserRole.Admin || currentUser?.Role == UserRole.Manager))
        {
            <div class="card">
                <div class="card-header bg-danger text-white">
                    <h5>Danger Zone</h5>
                </div>
                <div class="card-body">
                    <button type="button" class="btn btn-danger w-100" onclick="showCancelModal()">
                        <i class="bi bi-x-circle"></i> Cancel Sale
                    </button>
                </div>
            </div>
        }
    </div>
</div>

<!-- Cancel Sale Modal -->
<div class="modal fade" id="cancelModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Cancel Sale</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="CancelSale" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="modal-body">
                    <p>Are you sure you want to cancel this sale?</p>
                    <p class="text-danger">This will restore all items to inventory.</p>

                    <div class="mb-3">
                        <label class="form-label">Reason for cancellation</label>
                        <textarea name="reason" class="form-control" rows="3" required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-check-circle"></i> Confirm Cancellation
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showCancelModal() {
            var modal = new bootstrap.Modal(document.getElementById('cancelModal'));
            modal.show();
        }
    </script>
}