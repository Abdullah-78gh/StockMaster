@model StockMaster.ViewModels.SalesReportViewModel
@{
    ViewData["Title"] = "Sales Report";
    var currentUser = ViewBag.CurrentUser as StockMaster.Models.User;
}

<div class="row mb-4">
    <div class="col">
        <h2><i class="bi bi-file-text"></i> Sales Report</h2>
    </div>
    <div class="col-auto">
        <a asp-action="ExportSalesReport" asp-route-startDate="@Model.StartDate.ToString("yyyy-MM-dd")" asp-route-endDate="@Model.EndDate.ToString("yyyy-MM-dd")" class="btn btn-success">
            <i class="bi bi-download"></i> Export to CSV
        </a>
    </div>
</div>

<!-- Date Filter -->
<div class="row mb-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-body">
                <form method="get" class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Start Date</label>
                        <input type="date" name="startDate" class="form-control" value="@Model.StartDate.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">End Date</label>
                        <input type="date" name="endDate" class="form-control" value="@Model.EndDate.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search"></i> Generate Report
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Report Summary -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <h6>Period</h6>
                <h5>@Model.StartDate.ToString("MMM dd, yyyy") - @Model.EndDate.ToString("MMM dd, yyyy")</h5>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white">
            <div class="card-body">
                <h6>Total Sales</h6>
                <h5>$@Model.TotalSales.ToString("N2")</h5>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-info text-white">
            <div class="card-body">
                <h6>Transactions</h6>
                <h5>@Model.TotalTransactions</h5>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-white">
            <div class="card-body">
                <h6>Average Sale</h6>
                <h5>$@((Model.TotalTransactions > 0 ? Model.TotalSales / Model.TotalTransactions : 0).ToString("N2"))</h5>
            </div>
        </div>
    </div>
</div>

<!-- Sales Chart -->
<div class="row mb-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5>Sales Trend</h5>
            </div>
            <div class="card-body">
                <canvas id="salesChart" style="height: 300px;"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Sales Details -->
<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5>Sales Details</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover" id="salesTable">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Invoice #</th>
                                <th>Cashier</th>
                                <th>Items</th>
                                <th>Sub Total</th>
                                <th>Tax</th>
                                <th>Discount</th>
                                <th>Total</th>
                                <th>Payment</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Sales != null && Model.Sales.Any())
                            {
                                @foreach (var sale in Model.Sales)
                                {
                                    <tr>
                                        <td>@sale.SaleDate.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td>@sale.InvoiceNumber</td>
                                        <td>@(sale.User?.FullName ?? "N/A")</td>
                                        <td>@(sale.SaleItems?.Count ?? 0)</td>
                                        <td>$@sale.SubTotal.ToString("N2")</td>
                                        <td>$@sale.TaxAmount.ToString("N2")</td>
                                        <td>$@sale.DiscountAmount.ToString("N2")</td>
                                        <td><strong>$@sale.TotalAmount.ToString("N2")</strong></td>
                                        <td>@sale.PaymentMethod</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="9" class="text-center">No sales data for the selected period</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="fw-bold">
                                <td colspan="4">Totals:</td>
                                <td>$@Model.Sales.Sum(s => s.SubTotal).ToString("N2")</td>
                                <td>$@Model.Sales.Sum(s => s.TaxAmount).ToString("N2")</td>
                                <td>$@Model.Sales.Sum(s => s.DiscountAmount).ToString("N2")</td>
                                <td>$@Model.Sales.Sum(s => s.TotalAmount).ToString("N2")</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        $(document).ready(function() {
            // Initialize DataTable
            $('#salesTable').DataTable({
                order: [[0, 'desc']],
                pageLength: 25
            });

            // Sales Chart
            var ctx = document.getElementById('salesChart').getContext('2d');

            @{
                    var chartLabels = new List<string>();
                    var chartValues = new List<decimal>();

                    if (Model.Sales != null)
                    {
                            var salesByDay = Model.Sales
                                    .GroupBy(s => s.SaleDate.Date)
                                    .OrderBy(g => g.Key);

                            foreach (var day in salesByDay)
                            {
                                    chartLabels.Add($"\"{day.Key.ToString("MMM dd")}\"");
                                    chartValues.Add(day.Sum(s => s.TotalAmount));
                            }
                    }
            }

            var chartData = {
                labels: [@Html.Raw(string.Join(",", chartLabels))],
                values: [@string.Join(",", chartValues.Select(v => v.ToString(System.Globalization.CultureInfo.InvariantCulture)))]
            };

            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: chartData.labels,
                    datasets: [{
                        label: 'Sales ($)',
                        data: chartData.values,
                        backgroundColor: 'rgba(54, 162, 235, 0.5)',
                        borderColor: 'rgb(54, 162, 235)',
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) {
                                    return '$' + value;
                                }
                            }
                        }
                    }
                }
            });
        });
    </script>
}